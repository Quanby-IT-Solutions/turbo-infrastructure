# =============================================================================
# Staging Environment — terraform.tfvars.example
# =============================================================================
# Copy to terraform.tfvars and fill in your values.
# When creating a new project: copy this whole staging/ folder,
# update project_name and domains, then run terraform apply.

# --- Project / Tagging ----------------------------------------------------

project_name = "turbo-template"   # Change per project (lowercase, hyphens only)
client_name  = "Quanby"
aws_region   = "ap-southeast-1"
auto_backup  = false

# --- EC2 ------------------------------------------------------------------

ec2_instance_type    = "t3.small"   # Upgrade to t3.medium if you need more RAM
ec2_key_name         = ""           # Leave empty → Terraform auto-creates key pair
                                    # Set to existing key name to reuse one
ec2_root_volume_size = 20

# Restrict to your team's IPs in production-like setups:
ec2_allowed_ssh_cidrs = ["0.0.0.0/0"]

# --- Services -------------------------------------------------------------
# Nginx on the EC2 reverse-proxies to these ports.
# Each entry creates an ECR repo + CloudWatch log group + opens the SG port.

services = {
  web = {
    port              = 3001
    health_check_path = "/"
    domain            = "stg-turbo.quanbyit.com"  # Point DNS A record → elastic_ip output
  }
  backend = {
    port              = 3000
    health_check_path = "/api/v1/health"
    domain            = "stg-turbo-be.quanbyit.com"
  }
}
